// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// TENANT & USER MANAGEMENT
// ========================================

model Tenant {
  tenant_id            Int      @id @default(autoincrement())
  admin_id             Int
  tenant_name          String
  loyal_point_per_unit Int?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  update_at            DateTime @updatedAt

  admin                Admin                @relation(fields: [admin_id], references: [admin_id])
  customers            Customer[]
  users                User[]
  shops                Shop[]
  product_categories   ProductCategory[]
  subscription_tenants SubscriptionTenant[]

  @@map("tenants")
}

model Admin {
  admin_id   Int       @id @default(autoincrement())
  manager_id Int?
  email      String    @unique
  password   String
  full_name  String
  phone      String?
  avatar     String?
  is_active  Boolean   @default(true)
  last_login DateTime?
  created_at DateTime  @default(now())

  tenants Tenant[]

  @@map("admins")
}

model Role {
  role_id     Int     @id @default(autoincrement())
  role_code   String  @unique
  description String?
  permissions Json?

  users User[]

  @@map("roles")
}

model User {
  user_id          Int       @id @default(autoincrement())
  tenant_id        Int?
  shop_id          Int?
  owner_manager_id Int? // ID of the owner who manages this user (for shop owners/managers)
  role_id          Int?
  email            String    @unique
  password         String
  username         String    @unique
  avatar           String?
  full_name        String
  phone            String?
  is_active        Boolean   @default(true)
  last_login       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenant_id], references: [tenant_id])
  shop   Shop?   @relation(fields: [shop_id], references: [shop_id])
  role   Role?   @relation(fields: [role_id], references: [role_id])

  // Self-reference for owner hierarchy
  owner         User?  @relation("UserOwner", fields: [owner_manager_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  managed_users User[] @relation("UserOwner")

  // Orders processed by this user
  orders Orders[] @relation("OrderUser")

  // Shifts where this user works
  shift_users ShiftCashier[] @relation("ShiftUsers")

  // Inventory transactions created by this user
  inventory_traits InventoryTrait[] @relation("InventoryTraitCreator")

  @@map("users")
}

// ========================================
// SHOP MANAGEMENT
// ========================================

model Shop {
  shop_id    Int      @id @default(autoincrement())
  tenant_id  Int
  shop_name  String
  address    String?
  phone      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  update_at  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenant_id], references: [tenant_id])
  users        User[]
  inventories  Inventory[]
  shifts       Shift[]
  merchandises Merchandise[]

  @@map("shops")
}

model Shift {
  shift_id     Int       @id @default(autoincrement())
  shop_id      Int
  start_time   DateTime
  end_time     DateTime?
  shift_status String?

  shop           Shop           @relation(fields: [shop_id], references: [shop_id])
  orders         Orders[]
  shift_cashiers ShiftCashier[]

  @@map("shifts")
}

model ShiftCashier {
  shift_id Int
  user_id  Int // User working as cashier in this shift

  shift Shift @relation(fields: [shift_id], references: [shift_id])
  user  User  @relation("ShiftUsers", fields: [user_id], references: [user_id])

  @@id([shift_id, user_id])
  @@map("shift_cashiers")
}

// ========================================
// CUSTOMER MANAGEMENT
// ========================================

model Customer {
  customer_id   Int      @id @default(autoincrement())
  tenant_id     Int
  phone         String
  full_name     String?
  member_rank   String?
  loyalty_point Int?     @default(0)
  created_at    DateTime @default(now())

  tenant                  Tenant                  @relation(fields: [tenant_id], references: [tenant_id])
  orders                  Orders[]
  merchandise_redemptions MerchandiseRedemption[]

  @@map("customers")
}

// ========================================
// PRODUCT & INVENTORY MANAGEMENT
// ========================================

model ProductCategory {
  category_id     Int     @id @default(autoincrement())
  par_category_id Int?
  tenant_id       Int
  category_name   String
  is_active       Boolean @default(true)

  tenant   Tenant    @relation(fields: [tenant_id], references: [tenant_id])
  products Product[]

  @@map("product_categories")
}

model Product {
  product_id   Int      @id @default(autoincrement())
  category_id  Int
  product_name String
  sku          String   @unique
  barcode      String?
  description  String?
  measure_unit String?
  basic_price  Decimal  @db.Decimal(10, 2)
  unit_price   Decimal  @db.Decimal(10, 2)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  category        ProductCategory @relation(fields: [category_id], references: [category_id])
  inventory_items InventoryItem[]
  order_items     OrderItem[]

  @@map("products")
}

model Inventory {
  inventory_id      Int       @id @default(autoincrement())
  shop_id           Int
  current_quantity  Int       @default(0)
  minimum_threshold Int?
  reorder_quantity  Int?
  last_restock_at   DateTime?
  update_at         DateTime  @updatedAt

  shop            Shop            @relation(fields: [shop_id], references: [shop_id])
  inventory_items InventoryItem[]

  @@map("inventories")
}

model InventoryItem {
  inventory_item_id Int      @id @default(autoincrement())
  product_id        Int
  inventory_id      Int
  quantity          Int      @default(0)
  reserved_quantity Int?     @default(0)
  updated_at        DateTime @updatedAt

  product          Product          @relation(fields: [product_id], references: [product_id])
  inventory        Inventory        @relation(fields: [inventory_id], references: [inventory_id])
  inventory_traits InventoryTrait[]

  @@map("inventory_items")
}

model InventoryTrait {
  inv_trait_id      Int      @id @default(autoincrement())
  inventory_item_id Int
  created_by        Int // User who created this trait/transaction
  inv_trait_type    String
  direction_sign    String
  quantity          Int
  quantity_before   Int
  quantity_after    Int
  created_at        DateTime @default(now())

  inventory_item InventoryItem @relation(fields: [inventory_item_id], references: [inventory_item_id])
  user           User          @relation("InventoryTraitCreator", fields: [created_by], references: [user_id])

  @@map("inventory_traits")
}

// ========================================
// MERCHANDISE & REWARDS
// ========================================

model Merchandise {
  merchandise_id   Int      @id @default(autoincrement())
  shop_id          Int
  merchandise_name String
  description      String?
  sku              String?
  barcode          String?
  point_required   Int
  total_quantity   Int
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  update_at        DateTime @updatedAt

  shop        Shop                    @relation(fields: [shop_id], references: [shop_id])
  redemptions MerchandiseRedemption[]

  @@map("merchandises")
}

model MerchandiseRedemption {
  merchandis_re_id Int      @id @default(autoincrement())
  customer_id      Int
  merchandise_id   Int
  shop_id          Int
  point_spent      Int
  redemption_date  DateTime @default(now())

  customer    Customer    @relation(fields: [customer_id], references: [customer_id])
  merchandise Merchandise @relation(fields: [merchandise_id], references: [merchandise_id])

  @@map("merchandise_redemptions")
}

// ========================================
// ORDERS & PAYMENTS
// ========================================

model Orders {
  order_id        Int       @id @default(autoincrement())
  shift_id        Int
  user_id         Int // User who processed this order (cashier)
  customer_id     Int?
  subtotal_amount Decimal   @db.Decimal(10, 2)
  order_status    String
  grand_total     Decimal   @db.Decimal(10, 2)
  notes           String?
  created_at      DateTime  @default(now())
  completed_at    DateTime?
  cancelled_at    DateTime?

  shift       Shift       @relation(fields: [shift_id], references: [shift_id])
  user        User        @relation("OrderUser", fields: [user_id], references: [user_id])
  customer    Customer?   @relation(fields: [customer_id], references: [customer_id])
  order_items OrderItem[]
  payments    Payment[]

  @@map("orders")
}

model OrderItem {
  order_item_id Int     @id @default(autoincrement())
  product_id    Int
  order_id      Int
  quantity      Int
  unit_price    Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [product_id], references: [product_id])
  order   Orders  @relation(fields: [order_id], references: [order_id])

  @@map("order_items")
}

model Payment {
  payment_id     Int      @id @default(autoincrement())
  order_id       Int
  amount_paid    Decimal  @db.Decimal(10, 2)
  currency       String   @default("VND")
  payment_method String
  payment_status String
  created_at     DateTime @default(now())
  update_at      DateTime @updatedAt

  order Orders @relation(fields: [order_id], references: [order_id])

  @@map("payments")
}

// ========================================
// SUBSCRIPTION MANAGEMENT
// ========================================

model Subscription {
  subscription_id Int     @id @default(autoincrement())
  package_code    String  @unique
  description     String?
  price           Decimal @db.Decimal(10, 2)
  billing_cycle   String
  features        Json?

  subscription_tenants SubscriptionTenant[]

  @@map("subscriptions")
}

model SubscriptionTenant {
  sub_tenant_id      Int      @id @default(autoincrement())
  subscription_id    Int
  tenant_id          Int
  number_of_renewals Int?     @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  is_expired         Boolean  @default(false)

  subscription          Subscription          @relation(fields: [subscription_id], references: [subscription_id])
  tenant                Tenant                @relation(fields: [tenant_id], references: [tenant_id])
  subscription_payments SubscriptionPayment[]

  @@map("subscription_tenants")
}

model SubscriptionPayment {
  sub_payment_id Int      @id @default(autoincrement())
  sub_tenant_id  Int
  method         String
  amount         Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  payment_status String

  subscription_tenant SubscriptionTenant @relation(fields: [sub_tenant_id], references: [sub_tenant_id])

  @@map("subscription_payments")
}
