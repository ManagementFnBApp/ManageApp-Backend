// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// SHOP & USER MANAGEMENT
// ========================================

model Role {
  id     Int     @id @default(autoincrement())
  role_code   String  @unique
  description String?
  permissions Json?

  users User[]

  @@map("roles")
}

model User {
  id          Int       @id @default(autoincrement())
  shop_id          Int?
  owner_manager_id Int? // ID of the owner who manages this user (for shop owners/managers)
  role_id          Int?
  email            String    @unique
  password         String
  username         String    @unique
  is_active        Boolean   @default(true)
  last_login       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  shop   Shop?   @relation(fields: [shop_id], references: [id])
  role   Role?   @relation(fields: [role_id], references: [id])

  // Self-reference for owner hierarchy
  owner         User?  @relation("UserOwner", fields: [owner_manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managed_users User[] @relation("UserOwner")

  // Orders processed by this user
  orders Orders[] @relation("OrderUser")

  // Shifts where this user works
  shift_users ShiftStaff[] @relation("ShiftUsers")

  // Inventory transactions created by this user
  inventory_traits InventoryTrait[] @relation("InventoryTraitCreator")

  profile Profile?

  @@map("users")
}

model Profile {
  id String   @id @default(uuid())
  user_id    Int      @unique
  full_name  String
  avatar     String?
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("profiles")
}

// ========================================
// SHOP MANAGEMENT
// ========================================

model Shop {
  id    Int      @id @default(autoincrement())
  shop_name  String
  address    String?
  phone      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  update_at  DateTime @updatedAt

  users        User[]
  customers            Customer[]
  inventories  Inventory[]
  shifts       Shift[]
  merchandises Merchandise[]
  shop_categories ShopCategory[]
  shop_subcriptions ShopSubscription[]

  @@map("shops")
}

model Shift {
  id     Int       @id @default(autoincrement())
  shop_id      Int
  start_time   DateTime
  end_time     DateTime?
  shift_status String?

  shop           Shop           @relation(fields: [shop_id], references: [id])
  orders         Orders[]
  shift_staffs ShiftStaff[]

  @@map("shifts")
}

model ShiftStaff {
  shift_id Int
  user_id  Int 

  shift Shift @relation(fields: [shift_id], references: [id])
  user  User  @relation("ShiftUsers", fields: [user_id], references: [id])

  @@id([shift_id, user_id])
  @@map("shift_staffs")
}

// ========================================
// CUSTOMER MANAGEMENT
// ========================================

model Customer {
  id   Int      @id @default(autoincrement())
  shop_id     Int
  phone         String
  full_name     String?
  loyalty_point Int?     @default(0)
  created_at    DateTime @default(now())

  shop                  Shop                  @relation(fields: [shop_id], references: [id])
  orders                  Orders[]
  merchandise_redemptions MerchandiseRedemption[]

  @@map("customers")
}

// ========================================
// PRODUCT & INVENTORY MANAGEMENT
// ========================================

model Category {
  id     Int     @id @default(autoincrement())
  category_name   String
  is_active       Boolean @default(true)

  shop_category   ShopCategory[] 
  products Product[]

  @@map("categories")
}

model ShopCategory {
  shop_id Int 
  category_id Int

  shop Shop   @relation(fields: [shop_id], references: [id])
  category    Category @relation(fields: [category_id], references: [id])

  @@id([shop_id, category_id])
}

model Product {
  id   Int      @id @default(autoincrement())
  category_id  Int
  product_name String
  sku          String   @unique
  barcode      String? 
  description  String?
  measure_unit String?
  import_price Decimal  @db.Decimal(10, 2)
  list_price   Decimal  @db.Decimal(10, 2)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  category        Category @relation(fields: [category_id], references: [id])
  inventory_items InventoryItem[]
  order_items     OrderItem[]

  @@map("products")
}

model Inventory {
  id      Int       @id @default(autoincrement())
  shop_id           Int
  current_quantity  Int       @default(0)
  minimum_threshold Int?
  reorder_quantity  Int?
  last_restock_at   DateTime?
  update_at         DateTime  @updatedAt

  shop            Shop            @relation(fields: [shop_id], references: [id])
  inventory_items InventoryItem[]

  @@map("inventories")
}

model InventoryItem {
  id Int      @id @default(autoincrement())
  product_id        Int
  inventory_id      Int
  quantity          Int      @default(0)
  reserved_quantity Int?     @default(0)
  updated_at        DateTime @updatedAt

  product          Product          @relation(fields: [product_id], references: [id])
  inventory        Inventory        @relation(fields: [inventory_id], references: [id])
  inventory_traits InventoryTrait[]

  @@map("inventory_items")
}

model InventoryTrait {
  id      Int      @id @default(autoincrement())
  inventory_item_id Int
  created_by        Int // User who created this trait/transaction
  inv_trait_type    String
  direction_sign    String
  quantity          Int
  quantity_before   Int
  quantity_after    Int
  created_at        DateTime @default(now())

  inventory_item InventoryItem @relation(fields: [inventory_item_id], references: [id])
  user           User          @relation("InventoryTraitCreator", fields: [created_by], references: [id])

  @@map("inventory_traits")
}

// ========================================
// MERCHANDISE & REWARDS
// ========================================

model Merchandise {
  id   Int      @id @default(autoincrement())
  shop_id          Int
  merchandise_name String
  description      String?
  sku              String?
  barcode          String?
  point_required   Int
  total_quantity   Int
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  update_at        DateTime @updatedAt

  shop        Shop                    @relation(fields: [shop_id], references: [id])
  redemptions MerchandiseRedemption[]

  @@map("merchandises")
}

model MerchandiseRedemption {
  id Int      @id @default(autoincrement())
  customer_id      Int
  merchandise_id   Int
  shop_id          Int
  point_spent      Int
  redemption_date  DateTime @default(now())

  customer    Customer    @relation(fields: [customer_id], references: [id])
  merchandise Merchandise @relation(fields: [merchandise_id], references: [id])

  @@map("merchandise_redemptions")
}

// ========================================
// ORDERS & PAYMENTS
// ========================================

model Orders {
  id     Int       @id @default(autoincrement())
  shift_id     Int
  user_id      Int // User who processed this order (cashier)
  customer_id  Int?
  total_amount Decimal   @db.Decimal(10, 2)
  order_status String
  notes        String?
  created_at   DateTime  @default(now())
  completed_at DateTime?
  cancelled_at DateTime?

  shift       Shift       @relation(fields: [shift_id], references: [id])
  user        User        @relation("OrderUser", fields: [user_id], references: [id])
  customer    Customer?   @relation(fields: [customer_id], references: [id])
  order_items OrderItem[]
  payments    Payment[]

  @@map("orders")
}

model OrderItem {
  id Int     @id @default(autoincrement())
  product_id    Int
  order_id      Int
  quantity      Int
  unit_price    Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [product_id], references: [id])
  order   Orders  @relation(fields: [order_id], references: [id])

  @@map("order_items")
}

model Payment {
  id     Int      @id @default(autoincrement())
  order_id       Int
  amount_paid    Decimal  @db.Decimal(10, 2)
  currency       String   @default("VND")
  payment_method String
  payment_status String
  created_at     DateTime @default(now())
  update_at      DateTime @updatedAt

  order Orders @relation(fields: [order_id], references: [id])

  @@map("payments")
}

// ========================================
// SUBSCRIPTION MANAGEMENT
// ========================================

model Subscription {
  id Int       @id @default(autoincrement())
  package_code    String    @unique
  description     String?
  price           Decimal   @db.Decimal(10, 2)
  billing_cycle   String
  features        Json?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
  deleted_at      DateTime? // Soft delete - thời điểm đánh dấu xóa (sau 30 ngày sẽ xóa thật)

  shop_subscriptions ShopSubscription[]

  @@map("subscriptions")
}

model ShopSubscription {
  id      Int       @id @default(autoincrement())
  subscription_id    Int
  shop_id          Int
  number_of_renewals Int?      @default(0)
  start_date         DateTime  @default(now())
  end_date           DateTime? // Nullable để migrate được, sẽ được set khi tạo mới hoặc renew
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  is_expired         Boolean   @default(false)

  subscription          Subscription          @relation(fields: [subscription_id], references: [id])
  shop                Shop                @relation(fields: [shop_id], references: [id])
  subscription_payments SubscriptionPayment[]

  @@map("shop_subscriptions")
}

model SubscriptionPayment {
  id Int      @id @default(autoincrement())
  sub_tenant_id  Int
  method         String
  amount         Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  payment_status String

  shop_subscription ShopSubscription @relation(fields: [sub_tenant_id], references: [id])

  @@map("subscription_payments")
}
